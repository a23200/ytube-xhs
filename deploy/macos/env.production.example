# Copy this file to .env on the Mac mini and fill secrets locally.
# The deployment scripts replace __APP_DIR__ with the selected install path.

XHS_RUNTIME_DIR=__APP_DIR__/runtime

# OpenAI-compatible LLM provider. Production default uses official DeepSeek API.
# BUSINESS_LLM_API_KEY has priority if both are set. Keep secrets only on the target Mac.
# Fill BUSINESS_LLM_API_KEY with your official DeepSeek API key after install.
BUSINESS_LLM_API_KEY=
XHS_LLM_API_KEY=
XHS_LLM_BASE_URL=https://api.deepseek.com
XHS_LLM_MODEL=deepseek-chat
XHS_LLM_REQUIRE_API_KEY=true
XHS_LLM_TIMEOUT_MS=90000
XHS_LLM_MAX_CHARS=80000
XHS_LLM_MAX_TOKENS=3000
XHS_LLM_RETRY_ATTEMPTS=3

# Concurrent task limits for unattended Mac mini deployment.
YTXHS_MAX_ANALYZE_WORKERS=1
YTXHS_MAX_PRODUCE_WORKERS=3

# Optional external image generation provider.
# If disabled, the app still renders PNG cards with the local Pillow template.
XHS_IMAGE_ENABLED=false
XHS_IMAGE_API_KEY=
XHS_IMAGE_BASE_URL=
XHS_IMAGE_MODEL=
XHS_IMAGE_REQUIRE_API_KEY=auto
XHS_IMAGE_SIZE=1024x1024
XHS_IMAGE_TIMEOUT_MS=120000

# faster-whisper settings for videos without usable subtitles.
XHS_WHISPER_MODEL=base
XHS_WHISPER_DEVICE=auto
XHS_WHISPER_COMPUTE_TYPE=default

# OCR provider: auto, paddleocr, tesseract, or none.
# Mac mini production default is tesseract via Homebrew; PaddleOCR is optional.
XHS_OCR_PROVIDER=auto

# Platform download settings. Douyin and some YouTube/Bilibili requests require fresh cookies even for public videos.
# For unattended launchd service, prefer a manually exported cookies.txt file if cookies are needed.
# Do NOT rely on Chrome profile cookies unless the service runs as the same logged-in user.
XHS_YTDLP_COOKIES_FILE=
XHS_YTDLP_COOKIES_FROM_BROWSER=
XHS_YTDLP_IMPERSONATE=

# yt-dlp network socket timeout. Lower values prevent long stalls on slow YouTube media fragments.
XHS_YTDLP_SOCKET_TIMEOUT_SECONDS=30

# Short-link redirects use a shorter timeout and transient page requests are retried with backoff.
XHS_YTDLP_REDIRECT_TIMEOUT_SECONDS=12
XHS_YTDLP_EXTRACT_ATTEMPTS=2
