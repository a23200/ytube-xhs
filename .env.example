# Runtime output directory. Relative paths are resolved from the project root.
XHS_RUNTIME_DIR=./runtime

# OpenAI-compatible LLM provider.
# BUSINESS_LLM_API_KEY has priority; XHS_LLM_API_KEY is also accepted.
BUSINESS_LLM_API_KEY=
XHS_LLM_API_KEY=
XHS_LLM_BASE_URL=https://api.openai.com/v1
XHS_LLM_MODEL=gpt-4o-mini
# auto requires keys for remote endpoints, but allows localhost OpenAI-compatible endpoints.
# Set false for local Ollama/vLLM-compatible servers without auth.
XHS_LLM_REQUIRE_API_KEY=auto
XHS_LLM_TIMEOUT_MS=60000
XHS_LLM_MAX_CHARS=60000
XHS_LLM_MAX_TOKENS=1200
XHS_LLM_RETRY_ATTEMPTS=3

# Independent worker limits. Analyze uses local media/Whisper resources, while
# Produce is mostly remote LLM I/O. Defaults are conservative for a Mac mini.
YTXHS_MAX_ANALYZE_WORKERS=1
YTXHS_MAX_PRODUCE_WORKERS=3

# Optional external image generation provider.
# When disabled, the system still renders PNG cards with the local Pillow template.
XHS_IMAGE_ENABLED=false
XHS_IMAGE_API_KEY=
XHS_IMAGE_BASE_URL=
XHS_IMAGE_MODEL=
XHS_IMAGE_REQUIRE_API_KEY=auto
XHS_IMAGE_SIZE=1024x1024
XHS_IMAGE_TIMEOUT_MS=120000

# faster-whisper settings for videos without subtitles.
XHS_WHISPER_MODEL=base
XHS_WHISPER_DEVICE=auto
XHS_WHISPER_COMPUTE_TYPE=default

# OCR provider: auto, paddleocr, tesseract, or none.
XHS_OCR_PROVIDER=auto
